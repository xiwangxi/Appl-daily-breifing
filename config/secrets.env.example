# 复制这个文件为 config/secrets.env 并填入真实的 key（该文件已在 .gitignore 中，不会被提交）。
# 在 GitHub Actions 中运行时，改为在仓库 Settings -> Secrets and variables -> Actions 里配置同名的 Secrets，
# 不需要这个文件。

# --- Telegram ---
# 找 @BotFather 创建机器人拿到的 token
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
# 你给机器人发一条 /start 后，访问 https://api.telegram.org/bot<TOKEN>/getUpdates 里的 chat.id
TELEGRAM_CHAT_ID=123456789
# 可选：第二个接收人的 chat id（同样要先让他给机器人发 /start）。只有大盘 Daily 会额外发给这个人。
TELEGRAM_CHAT_ID_2=

# --- Finnhub (新闻) ---
# https://finnhub.io/register 免费注册
# 分析师评级/目标价、期权数据都改用 yfinance 免费拿了，不需要 Finnhub 付费套餐
FINNHUB_API_KEY=

# --- Anthropic Claude API (新闻摘要/去重/排序) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- 可选 ---
# 摘要用的模型。默认用 Haiku 4.5（便宜、够用），想要更强的归纳质量可以换成 Opus 4.8。
CLAUDE_MODEL=claude-haiku-4-5-20251001
